---
// RegaloQR.astro
---

<section class="pt-2 md:py-12 lg:py-16 px-4 relative overflow-hidden">
  <div class="absolute inset-0 z-0"></div>

  <div class="max-w-4xl mx-auto relative z-10">
    <div class="relative">
      <!-- HOJA LATERAL IZQUIERDA -->
      <div
        class="absolute -left-8 md:-left-16 top-[80px] -translate-y-1/2 w-16 md:w-28 pointer-events-none z-0"
        id="hoja-qr-izq"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Hoja decorativa"
          class="w-full h-auto object-contain"
        />
      </div>

      <!-- HOJA LATERAL DERECHA -->
      <div
        class="absolute -right-8 md:-right-16 top-[80px] -translate-y-1/2 w-16 md:w-28 pointer-events-none z-0"
        id="hoja-qr-der"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Hoja decorativa"
          class="w-full h-auto object-contain -scale-x-100"
        />
      </div>

      <!-- SEPARADOR SUPERIOR -->
      <div class="flex justify-center mb-6" id="separador-qr-top">
        <img
          src="/imagenes/separador.png"
          alt="Separador decorativo"
          class="w-32 md:w-40 lg:w-48 h-auto object-contain opacity-90"
        />
      </div>

      <!-- TÍTULO -->
      <div class="text-center mb-8" id="titulo-qr">
        <h2
          class="font-charm text-xl md:text-3xl lg:text-4xl font-bold mb-4"
          style="color: #D4AF37;"
        >
          MESA DE REGALOS
        </h2>
        <div class="flex items-center justify-center gap-3">
          <div
            class="w-16 h-[2px]"
            style="background: linear-gradient(to right, transparent, #D4AF37);"
          >
          </div>
          <div class="w-2 h-2 rounded-full" style="background: #D4AF37;"></div>
          <div
            class="w-16 h-[2px]"
            style="background: linear-gradient(to left, transparent, #D4AF37);"
          >
          </div>
        </div>
      </div>

      <!-- MENSAJE PRINCIPAL -->
      <div class="max-w-2xl mx-auto mb-8" id="mensaje-qr">
        <p
          class="font-charm text-xl md:text-2xl text-center leading-relaxed"
          style="color: #D4748A;"
        >
          Su presencia es nuestro mejor regalo. Si desean obsequiarnos algo más,
          con gusto aceptaremos un detalle; los sobres estarán disponibles en el
          evento.
        </p>
      </div>

      <!-- CARD PRINCIPAL -->
      <div
        id="card-qr"
        class="relative rounded-3xl p-6 md:p-10 mx-auto max-w-lg"
        style="
          background: linear-gradient(135deg, rgba(253,236,234,0.6), rgba(244,184,193,0.3), rgba(212,175,55,0.08));
          border: 1px solid rgba(244,184,193,0.6);
          box-shadow: 0 8px 32px rgba(232,147,154,0.18), inset 0 1px 0 rgba(255,255,255,0.7);
          backdrop-filter: blur(12px);
        "
      >
        <!-- Lluvia de sobres animados -->
        <div
          id="sobres-lluvia"
          class="absolute inset-0 overflow-hidden rounded-3xl pointer-events-none z-0"
        >
        </div>

        <div class="relative z-10" id="qr-container">
          <!-- Icono sobre grande decorativo arriba -->
          <div class="flex justify-center mb-4">
            <div class="relative">
              <svg
                width="64"
                height="64"
                viewBox="0 0 64 64"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect
                  x="4"
                  y="14"
                  width="56"
                  height="38"
                  rx="5"
                  fill="#F4B8C1"
                  stroke="#D4748A"
                  stroke-width="2"></rect>
                <path
                  d="M4 19 L32 38 L60 19"
                  stroke="#D4748A"
                  stroke-width="2"
                  fill="none"></path>
                <path d="M4 52 L22 34" stroke="#E8939A" stroke-width="1.5"
                ></path>
                <path d="M60 52 L42 34" stroke="#E8939A" stroke-width="1.5"
                ></path>
              </svg>
              <div
                class="absolute -top-1 -right-1 w-4 h-4 rounded-full"
                style="background: radial-gradient(circle, #D4AF37, transparent);"
              >
              </div>
            </div>
          </div>

          <!-- Texto sobre QR -->
          <p
            class="text-center font-charm text-lg mb-5"
            style="color: #D4AF37;"
          >
            ✨ Escanea para enviarnos un regalo ✨
          </p>

          <!-- QR GRANDE -->
          <div class="flex justify-center mb-5">
            <div
              class="relative p-4 rounded-2xl"
              style="
                background: white;
                border: 2px solid rgba(212,175,55,0.4);
                box-shadow: 0 6px 24px rgba(232,147,154,0.2), 0 0 0 6px rgba(244,184,193,0.15);
              "
            >
              <!-- Marco decorativo dorado en esquinas -->
              <div
                class="absolute top-1 left-1 w-5 h-5 border-t-2 border-l-2 rounded-tl"
                style="border-color: #D4AF37;"
              >
              </div>
              <div
                class="absolute top-1 right-1 w-5 h-5 border-t-2 border-r-2 rounded-tr"
                style="border-color: #D4AF37;"
              >
              </div>
              <div
                class="absolute bottom-1 left-1 w-5 h-5 border-b-2 border-l-2 rounded-bl"
                style="border-color: #D4AF37;"
              >
              </div>
              <div
                class="absolute bottom-1 right-1 w-5 h-5 border-b-2 border-r-2 rounded-br"
                style="border-color: #D4AF37;"
              >
              </div>

              <!-- Imagen QR -->
              <img
                src="/imagenes/qr.png"
                alt="Código QR Mesa de Regalos"
                class="w-52 h-52 md:w-64 md:h-64 object-contain"
              />
            </div>
          </div>

          <!-- Texto inferior -->
          <p
            class="text-center text-sm font-medium"
            style="color: rgba(212,116,138,0.7);"
          >
            💗 Con amor, gracias por celebrar conmigo 💗
          </p>
        </div>
      </div>

      <!-- DECORACIÓN INFERIOR -->
      <div class="flex justify-center gap-3 mt-8" id="decoracion-qr">
        <div class="flex gap-2 items-center">
          <div class="w-2 h-2 rounded-full" style="background: #E8939A;"></div>
          <div class="w-3 h-3 rounded-full" style="background: #D4AF37;"></div>
          <div class="w-2 h-2 rounded-full" style="background: #E8939A;"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      function generarSobres() {
        const container = document.getElementById("sobres-lluvia");
        if (!container) return;

        const emojis = ["✉️", "💌", "💝", "🎁", "💗"];
        for (let i = 0; i < 12; i++) {
          const sobre = document.createElement("div");
          sobre.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
          const size = Math.random() * 16 + 10;
          sobre.style.cssText = `
            position: absolute;
            font-size: ${size}px;
            left: ${Math.random() * 100}%;
            top: -30px;
            opacity: 0;
            pointer-events: none;
          `;
          container.appendChild(sobre);

          gsap.to(sobre, {
            y: container.offsetHeight + 40,
            opacity: 0.35,
            rotation: Math.random() * 60 - 30,
            duration: Math.random() * 4 + 4,
            delay: Math.random() * 6,
            ease: "none",
            repeat: -1,
            repeatDelay: Math.random() * 3,
            onRepeat: () => {
              gsap.set(sobre, {
                y: -30,
                left: `${Math.random() * 100}%`,
                opacity: 0,
              });
            },
          });
        }
      }

      gsap.set("#hoja-qr-izq", { opacity: 0, x: -50 });
      gsap.set("#hoja-qr-der", { opacity: 0, x: 50 });
      gsap.set("#separador-qr-top", { opacity: 0, scale: 0.8 });
      gsap.set("#titulo-qr", { opacity: 0, scale: 0.8 });
      gsap.set("#mensaje-qr", { opacity: 0, scale: 0.8 });
      gsap.set("#card-qr", { opacity: 0, scale: 0.8 });
      gsap.set("#decoracion-qr", { opacity: 0, scale: 0.8 });

      ScrollTrigger.create({
        trigger: "#separador-qr-top",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          gsap.to(
            "#separador-qr-top, #titulo-qr, #mensaje-qr, #card-qr, #decoracion-qr",
            {
              opacity: 1,
              scale: 1,
              duration: 1.2,
              ease: "back.out(1.4)",
            },
          );

          gsap.to("#hoja-qr-izq, #hoja-qr-der", {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power3.out",
          });

          generarSobres();

          gsap.to("#hoja-qr-izq", {
            y: -8,
            rotation: -3,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.2,
          });
          gsap.to("#hoja-qr-der", {
            y: -8,
            rotation: 3,
            duration: 3,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });

          gsap.to("#decoracion-qr > div > div", {
            scale: 1.3,
            opacity: 0.4,
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            stagger: 0.15,
            delay: 1.5,
          });
        },
        onLeaveBack: () => {
          gsap.set("#hoja-qr-izq", { opacity: 0, x: -50 });
          gsap.set("#hoja-qr-der", { opacity: 0, x: 50 });
          gsap.set("#separador-qr-top", { opacity: 0, scale: 0.8 });
          gsap.set("#titulo-qr", { opacity: 0, scale: 0.8 });
          gsap.set("#mensaje-qr", { opacity: 0, scale: 0.8 });
          gsap.set("#card-qr", { opacity: 0, scale: 0.8 });
          gsap.set("#decoracion-qr", { opacity: 0, scale: 0.8 });
        },
      });
    });
  }
</script>

<style>
  #card-qr {
    transition: all 0.3s ease;
  }

  #card-qr:hover {
    box-shadow:
      0 25px 60px rgba(212, 175, 55, 0.2),
      0 8px 32px rgba(232, 147, 154, 0.2) !important;
    transform: translateY(-5px);
  }

  #hoja-qr-izq,
  #hoja-qr-der {
    will-change: transform;
  }

  #separador-qr-top img {
    transition: all 0.3s ease;
  }

  #separador-qr-top:hover img {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  #decoracion-qr > div > div {
    transition: all 0.3s ease;
  }

  #mensaje-qr p {
    transition: color 0.3s ease;
  }
</style>
